# ===== 必填：Anthropic API =====
ANTHROPIC_API_KEY=sk-ant-你的金鑰

# ===== 必填：Email 設定（以 Gmail 為例）=====
# Gmail 需開啟「應用程式密碼」：Google 帳戶 > 安全性 > 兩步驟驗證 > 應用程式密碼
EMAIL_SENDER=your@gmail.com
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
EMAIL_RECIPIENTS=qiukecheng41@gmail.com

# ===== 選填：NewsAPI（可增加新聞來源，免費版每日 100 次）=====
NEWS_API_KEY=

# ===== 每日執行時間（24 小時制）=====
DAILY_RUN_TIME=08:00

# ===== 分析設定 =====
MAX_NEWS_ITEMS=80

# ===== SMTP 設定（Gmail 預設，不需修改）=====
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
